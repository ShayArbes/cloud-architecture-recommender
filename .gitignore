*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
wheels/

# Virtual environments
venv/
.venv/
env/
ENV/

# Test / type-check / lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# ============================================================
