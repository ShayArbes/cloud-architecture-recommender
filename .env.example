# ============================================================
# Cloud Architecture Recommender — environment variables
# ------------------------------------------------------------
# Copy to `.env` and adjust. NEVER commit the real `.env`.
# Every variable used by any component MUST be listed here
# with a comment and a dummy/safe default (CLAUDE.md §8).
# ============================================================

# --- MongoDB -------------------------------------------------
# Inside Docker Compose the host is the service name `mongo`;
# for local (non-Docker) development use localhost.
MONGO_URI=mongodb://mongo:27017
MONGO_DB_NAME=cloud_arch_db
# Host port docker-compose publishes MongoDB on (change if 27017 is
# already taken by a locally installed MongoDB).
MONGO_HOST_PORT=27017

# --- Backend API (FastAPI) ----------------------------------
API_HOST=0.0.0.0
API_PORT=8000
# development | production — controls docs exposure & log verbosity
ENVIRONMENT=development
LOG_LEVEL=INFO
# Comma-separated origins allowed by CORS (the frontend dev/prod URLs)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Scraper -------------------------------------------------
# Max concurrent page fetches (keep polite)
SCRAPER_MAX_CONCURRENCY=3
# Per-request timeout in seconds
SCRAPER_TIMEOUT_SECONDS=15

# --- AI parsing (OPTIONAL) ----------------------------------
# Leave empty to use the rule-based fallback parser.
# The application MUST run correctly with this unset (CLAUDE.md §2).
ANTHROPIC_API_KEY=

# --- Frontend (Vite — must be prefixed with VITE_) ----------
VITE_API_BASE_URL=http://localhost:8000/api/v1

# --- Frontend container (Docker) -----------------------------
# Host port the built frontend is served on by nginx
FRONTEND_PORT=3000
