# Normalize line endings across platforms.
# Text files are stored with LF in the repo; Git converts on checkout per-OS.
* text=auto eol=lf

# Files that MUST stay LF (break if CRLF is introduced on Windows checkouts).
*.sh text eol=lf
Dockerfile text eol=lf
*.py text eol=lf

# Binary files — never normalize.
*.png binary
*.jpg binary
*.pdf binary
*.ico binary
